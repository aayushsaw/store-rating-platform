# Root environment template — copy to .env for local overrides if needed.
# Package-specific templates live in client/.env.example and server/.env.example

# PostgreSQL (used by docker-compose and server)
POSTGRES_USER=store_rating
POSTGRES_PASSWORD=store_rating_secret
POSTGRES_DB=store_rating_db
POSTGRES_PORT=5432

# Server
DATABASE_URL=postgresql://store_rating:store_rating_secret@localhost:5432/store_rating_db?schema=public
SERVER_PORT=3001
NODE_ENV=development

# Client
VITE_API_BASE_URL=http://localhost:3001/api/v1
