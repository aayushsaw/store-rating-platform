# Server environment — copy to server/.env

DATABASE_URL=postgresql://store_rating:store_rating_secret@localhost:5432/store_rating_db?schema=public
SERVER_PORT=3001
NODE_ENV=development

# JWT secrets (required in M1)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-random
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12

# CORS
CLIENT_ORIGIN=http://localhost:5173
